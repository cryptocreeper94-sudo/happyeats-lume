# ═══════════════════════════════════════════════════════════
# HappyEats Lume — Environment Configuration
# ═══════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development
APP_URL=https://happyeats.app
APP_DOMAIN=happyeats.app

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Authentication
HE_JWT_SECRET=your-jwt-secret-here
JWT_SECRET=your-jwt-secret-here

# OpenAI (for AI subsystems: menu scan, cert check, flyer gen)
OPENAI_API_KEY=sk-your-key-here

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here

# Resend (email notifications)
RESEND_API_KEY=re_your-key-here

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Owner notifications
OWNER_EMAIL=owner@happyeats.app
OWNER_PHONE=+1xxxxxxxxxx

# ElevenLabs (TTS - optional)
ELEVEN_LABS_API_KEY=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
